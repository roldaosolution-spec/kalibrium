APP_NAME=Kalibrium
APP_ENV=local
APP_KEY= # Run: php artisan key:generate
APP_DEBUG=false # Set true only for local dev
APP_TIMEZONE=America/Sao_Paulo
APP_URL=http://localhost
APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file

# ─── Banco de dados (PostgreSQL 18) ───────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=kalibrium
DB_USERNAME=kalibrium
DB_PASSWORD=

# ─── Redis 8 ──────────────────────────────────────────────────────────────────
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_USERNAME=
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_SESSION_DB=2

# ─── Cache / Sessão ───────────────────────────────────────────────────────────
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=5760
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

# ─── Filas ────────────────────────────────────────────────────────────────────
QUEUE_CONNECTION=redis
BROADCAST_CONNECTION=log

# ─── Logs ─────────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── Email ────────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@kalibrium.com.br"
MAIL_FROM_NAME="${APP_NAME}"

# ─── Storage (S3 / MinIO) ─────────────────────────────────────────────────────
FILESYSTEM_DISK=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=sa-east-1
AWS_BUCKET=kalibrium
AWS_USE_PATH_STYLE_ENDPOINT=false

# ─── Sanctum / JWT ────────────────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=localhost

# ─── Fortify / 2FA ────────────────────────────────────────────────────────────
FORTIFY_USERNAME=email
FORTIFY_2FA_SECRET_LENGTH=32

# ─── Observabilidade ──────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=kalibrium

# ─── Vite ─────────────────────────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"

# ─── Fiscal (NFS-e) ───────────────────────────────────────────────────────────
NFSE_AMBIENTE=homologacao
NFSE_CERTIFICADO_PATH=
NFSE_CERTIFICADO_SENHA=

# ─── WhatsApp / Notificações ──────────────────────────────────────────────────
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=

# ─── FCM (Push Notifications) ─────────────────────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
